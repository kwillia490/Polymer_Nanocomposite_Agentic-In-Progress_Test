Generated 3 of 3 mixed pair_coeff terms from sixthpower/sixthpower mixing rule
shell pigz ${myid}_NPT${npt}x20ps.dat
shell pigz PE_IFFDfyS0_NPT${npt}x20ps.dat
shell pigz PE_IFFDfyS0_NPT50x20ps.dat
if "${npt} > 1" then "shell rm ${myid}_NPT$(v_npt-1)x20ps.dat.gz"
shell rm ${myid}_NPT$(v_npt-1)x20ps.dat.gz
shell rm PE_IFFDfyS0_NPT$(v_npt-1)x20ps.dat.gz
shell rm PE_IFFDfyS0_NPT49x20ps.dat.gz
next npt
jump SELF npt_loop
unfix 1
unfix 2

variable    rho equal ${target_density} # density in g/cc
variable    rho equal 1.26 
variable    velocity_angperns equal 20 # rate of densifying in A/ns
variable    erate equal $(v_velocity_angperns/lz) # Calculate strain rate in 1/ns
variable    erate equal 0.59795288883199482211 
variable    erate_fs equal $(v_erate/10^6) # Convert strain rate to 1/fs
variable    erate_fs equal 5.9795288883199506671e-07 
variable    rhoa equal ${rho}/(10^8)^3 # density of PLA in g/A^3
variable    rhoa equal 1.26/(10^8)^3 
variable    masssys equal $(vol*density*(10^-8)^3) # mass of system in g
variable    masssys equal 2.329252889382135256e-20 
variable    finalvol equal $(v_masssys/v_rhoa) # final volume needed to achieve v_rhoa density
variable    finalvol equal 18486.134042715399119 
variable    lf equal $(v_finalvol^(1/3)) # final length of cubic box needed to achieve v_rhoa density
variable    lf equal 26.441253055552980555 
variable    dlx equal abs(v_lf-lx)
variable    dly equal abs(v_lf-ly)
variable    dlz equal abs(v_lf-lz)
variable	delta_t equal $(round(abs((v_lf/lz-1)/v_erate_fs))) # Calculate time in fs to deform the length at the specified rate
variable	delta_t equal 350310 

# Debugging
variable	volume equal vol
variable    v0 equal ${volume}
variable    v0 equal 37418.7333129339
print 'current volume of system is ${v0} A^3'
current volume of system is 37418.7333129339 A^3
print 'mass of system is ${masssys} g'
mass of system is 2.32925288938214e-20 g
print 'lxi = $(lx) A'
lxi = 33.447451084427065382 A
print 'lyi = $(ly) A'
lyi = 33.447451084427065382 A
print 'lzi = $(lz) A'
lzi = 33.447451084427065382 A
print 'lf = ${lf} A'
lf = 26.441253055553 A
print 'dlx = $(v_dlx) A'
dlx = 7.0061980288740697276 A
print 'dly = $(v_dly) A'
dly = 7.0061980288740697276 A
print 'dlz = $(v_dlz) A'
dlz = 7.0061980288740697276 A
print 'strain rate used as erate is ${erate_fs} 1/fs'
strain rate used as erate is 5.97952888831995e-07 1/fs
print 'Runtime = ${delta_t} fs'
Runtime = 350310 fs
print 'strain rate in x is $((v_lf/lx-1)/v_delta_t) 1/fs'
strain rate in x is -5.9795272060379033465e-07 1/fs
print 'strain rate in y is $((v_lf/ly-1)/v_delta_t) 1/fs'
strain rate in y is -5.9795272060379033465e-07 1/fs
print 'strain rate in z is $((v_lf/lz-1)/v_delta_t) 1/fs'
strain rate in z is -5.9795272060379033465e-07 1/fs

fix 1 all nvt temp 300 300 1000
fix 2 all deform 1 x final -$(v_lf/2) $(v_lf/2) y final -$(v_lf/2) $(v_lf/2) z final -$(v_lf/2) $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 $(v_lf/2) y final -$(v_lf/2) $(v_lf/2) z final -$(v_lf/2) $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 13.220626527776499159 y final -$(v_lf/2) $(v_lf/2) z final -$(v_lf/2) $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 13.220626527776499159 y final -13.220626527776499159 $(v_lf/2) z final -$(v_lf/2) $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 13.220626527776499159 y final -13.220626527776499159 13.220626527776499159 z final -$(v_lf/2) $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 13.220626527776499159 y final -13.220626527776499159 13.220626527776499159 z final -13.220626527776499159 $(v_lf/2)
fix 2 all deform 1 x final -13.220626527776499159 13.220626527776499159 y final -13.220626527776499159 13.220626527776499159 z final -13.220626527776499159 13.220626527776499159
fix 3 all balance 10000 1.05 shift xyz 20 1.05
run $(v_delta_t)
run 350310
